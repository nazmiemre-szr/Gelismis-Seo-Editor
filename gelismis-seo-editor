// A. Başlıkları Basma Logic'i
add_filter( 'pre_get_document_title', 'gse_render_title', 999 );
function gse_render_title($title) {
    
    if ( is_page() ) {
        $custom_title = get_post_meta(get_the_ID(), '_gse_title', true);
        // Özel başlık girildiyse SADECE onu göster (ek ekleme)
        if ( !empty($custom_title) ) return $custom_title;
        
        // Girilmediyse varsayılan sayfa başlığı + ayarlardaki eki göster
        $suffix = get_option('gse_page_suffix', '');
        return get_the_title() . (!empty($suffix) ? " " . $suffix : "");
        
    } elseif ( is_singular('post') ) {
        $custom_title = get_post_meta(get_the_ID(), '_gse_title', true);
        if ( !empty($custom_title) ) return $custom_title;
        
        $suffix = get_option('gse_post_suffix', '');
        return get_the_title() . (!empty($suffix) ? " " . $suffix : "");
        
    } elseif ( is_category() ) {
        $custom_title = get_term_meta(get_queried_object_id(), 'seo_title', true);
        if ( !empty($custom_title) ) return $custom_title;
        
        $suffix = get_option('gse_category_suffix', '');
        return single_cat_title('', false) . (!empty($suffix) ? " " . $suffix : "");
    }

    return $title;
}

// B. Description Basma (Otomatik Çekme Özelliği Eklendi)
add_action( 'wp_head', function() {
    $desc = "";
    
    if ( is_singular() ) {
        // Önce özel SEO açıklaması var mı diye bak
        $desc = get_post_meta(get_the_ID(), '_gse_desc', true);
        
        // Yoksa yazının özetini veya içeriğini al
        if ( empty($desc) ) {
            $post = get_post();
            $desc = has_excerpt() ? get_the_excerpt() : wp_trim_words( $post->post_content, 25, '' );
        }
    } elseif ( is_category() ) {
        // Önce özel SEO açıklaması var mı diye bak
        $desc = get_term_meta(get_queried_object_id(), 'seo_desc', true);
        
        // Yoksa kategorinin kendi HTML açıklamasını al (HTML etiketlerini temizleyerek)
        if ( empty($desc) ) {
            $desc = category_description();
        }
    }
    
    // HTML etiketlerini, kısa kodları ve boşlukları temizle
    $desc = wp_strip_all_tags( strip_shortcodes( $desc ) );
    $desc = trim( preg_replace( '/\s+/', ' ', $desc ) );
    
    // Açıklama doluysa, ilk 160 karakteri keserek meta etiketini bas
    if ( !empty($desc) ) {
        $desc = mb_substr( $desc, 0, 160, 'UTF-8' );
        echo '<meta name="description" content="' . esc_attr($desc) . '" />' . "\n";
    }
}, 1 );

// C. Meta Etiket Temizleyici (Çıktı Tamponlaması ile kesin çözüm)
add_action('wp_head', 'gse_start_head_buffer', 0);
add_action('wp_head', 'gse_end_head_buffer', 9999);

function gse_start_head_buffer() { ob_start(); }
function gse_end_head_buffer() {
    $head = ob_get_clean();
    
    // Generator Temizliği
    if ( get_option('gse_remove_generator') == '1' ) {
        remove_action('wp_head', 'wp_generator'); 
        add_filter('the_generator', '__return_false');
        $head = preg_replace('/<meta name=["\']generator["\'][^>]*>\s*/i', '', $head);
    }
    
    // Sayfalarda Tarih Temizliği
    if ( get_option('gse_remove_page_dates') == '1' && is_page() ) {
        $head = preg_replace('/<meta (property|name)=["\'](article:published_time|article:modified_time|og:updated_time|date|revised|last-modified)["\'][^>]*>\s*/i', '', $head);
    }
    
    echo $head;
}

/** ====================================================================
 * 7. SİTE HARİTASI (XML SITEMAP) 
 * ================================================================== */
add_action( 'init', function() {
    add_rewrite_rule( '^sitemap\.xml$', 'index.php?gse_sitemap=1', 'top' );
});

add_filter( 'query_vars', function($vars) {
    $vars[] = 'gse_sitemap';
    return $vars;
});

add_action( 'template_redirect', function() {
    if ( get_query_var( 'gse_sitemap' ) ) {
        header( 'Content-Type: application/xml; charset=utf-8' );
        echo '<?xml version="1.0" encoding="UTF-8"?>';
        echo '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">';
        
        $posts = get_posts(['post_type' => ['post', 'page'], 'posts_per_page' => -1]);
        foreach($posts as $post) {
            echo '<url><loc>'.get_permalink($post->ID).'</loc><lastmod>'.get_the_modified_date('c', $post->ID).'</lastmod></url>';
        }
        
        $cats = get_terms(['taxonomy' => 'category']);
        foreach($cats as $cat) {
            echo '<url><loc>'.get_term_link($cat).'</loc></url>';
        }
        echo '</urlset>';
        exit;
    }
});

